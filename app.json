{
  "expo": {
    "name": "Nutrivio",
    "slug": "nutrivio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "nutrivio",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0D12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutrivio.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0D12"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nutrivio.app"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
